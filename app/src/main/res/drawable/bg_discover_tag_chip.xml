<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/ui_action_radius" />
            <solid android:color="#36FFFFFF" />
            <stroke
                android:width="1dp"
                android:color="?attr/colorAccent" />
        </shape>
    </item>

    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/ui_action_radius" />
            <gradient
                android:angle="270"
                android:endColor="#2AFFFFFF"
                android:startColor="#42FFFFFF" />
            <stroke
                android:width="1dp"
                android:color="?attr/colorAccent" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/ui_action_radius" />
            <gradient
                android:angle="270"
                android:endColor="#1CFFFFFF"
                android:startColor="#2EFFFFFF" />
            <stroke
                android:width="1dp"
                android:color="#76FFFFFF" />
        </shape>
    </item>

</selector>
