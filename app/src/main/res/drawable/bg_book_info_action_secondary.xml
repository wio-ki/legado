<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/ui_action_radius" />
            <solid android:color="@color/btn_bg_press" />
            <stroke
                android:width="1dp"
                android:color="@color/glass_stroke" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/ui_action_radius" />
            <solid android:color="@color/book_info_frost" />
            <stroke
                android:width="1dp"
                android:color="@color/glass_stroke" />
        </shape>
    </item>
</selector>
