<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="#2E2E5274" />
            <stroke
                android:width="1dp"
                android:color="#6EAED6F2" />
        </shape>
    </item>

    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="#263A6286" />
            <stroke
                android:width="1dp"
                android:color="#62A9D3EE" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <gradient
                android:angle="270"
                android:endColor="#1A2D4A66"
                android:startColor="#14385D82" />
            <stroke
                android:width="1dp"
                android:color="#4C8EC0E2" />
        </shape>
    </item>

</selector>
