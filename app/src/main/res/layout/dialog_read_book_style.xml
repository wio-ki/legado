<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tool="http://schemas.android.com/tools"
    android:id="@+id/root_view"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipToPadding="false"
    android:fillViewport="false"
    android:overScrollMode="ifContentScrolls">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingTop="8dp"
        android:paddingEnd="14dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:minHeight="40dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_name_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/style_name"
                android:textColor="@color/primaryText"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="4dp"
                android:ellipsize="end"
                android:maxWidth="140dp"
                android:singleLine="true"
                android:textColor="@color/secondaryText" />

            <ImageView
                android:id="@+id/iv_edit"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/edit"
                android:padding="8dp"
                android:src="@drawable/ic_edit"
                app:tint="@color/secondaryText" />

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tv_restore"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackground"
                android:gravity="center"
                android:minWidth="48dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="管理样式"
                android:textColor="@color/primaryText" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/tab_edit_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:minHeight="40dp"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingTop="4dp"
            android:paddingEnd="8dp"
            android:paddingBottom="4dp">

            <TextView
                android:id="@+id/btn_tab_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:minHeight="34dp"
                android:text="@string/text_font"
                android:textColor="@color/primaryText"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btn_tab_style"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:minHeight="34dp"
                android:text="颜色和背景"
                android:textColor="@color/primaryText"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btn_tab_page"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:minHeight="34dp"
                android:text="@string/more"
                android:textColor="@color/primaryText"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/ll_text_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/panel_text_tools"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/row_text_font_weight"
                    style="@style/ReadColorRow">

                    <TextView
                        style="@style/ReadColorRowTitle"
                        android:text="@string/text_font_weight_converter" />

                    <io.legado.app.ui.book.read.config.TextFontWeightConverter
                        android:id="@+id/text_font_weight_converter"
                        style="@style/ReadColorRowValue"
                        android:gravity="end|center_vertical"
                        android:textSize="14sp" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/row_text_font"
                    style="@style/ReadColorRow">

                    <TextView
                        style="@style/ReadColorRowTitle"
                        android:text="@string/text_font" />

                    <TextView
                        android:id="@+id/tv_text_font"
                        style="@style/ReadColorRowValue"
                        android:gravity="end|center_vertical"
                        android:singleLine="true"
                        android:text="@string/text_font"
                        android:textSize="14sp" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/row_text_indent"
                    style="@style/ReadColorRow">

                    <TextView
                        style="@style/ReadColorRowTitle"
                        android:text="@string/text_indent" />

                    <TextView
                        android:id="@+id/tv_text_indent"
                        style="@style/ReadColorRowValue"
                        android:gravity="end|center_vertical"
                        android:singleLine="true"
                        android:text="@string/text_indent"
                        android:textSize="14sp" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/row_text_underline"
                    style="@style/ReadColorRow">

                    <TextView
                        style="@style/ReadColorRowTitle"
                        android:text="@string/text_underline" />

                    <TextView
                        android:id="@+id/tv_text_underline_value"
                        style="@style/ReadColorRowValue" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/row_text_shadow"
                    style="@style/ReadColorRow">

                    <io.legado.app.ui.widget.DetailSeekBar
                        android:id="@+id/dsb_text_shadow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:isBottomBackground="true"
                        app:max="100"
                        app:title="@string/text_shadow" />

                </LinearLayout>


            </LinearLayout>

            <LinearLayout style="@style/ReadColorRow">

                <io.legado.app.ui.widget.DetailSeekBar
                    android:id="@+id/dsb_text_size"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:max="45"
                    app:title="@string/text_size" />

            </LinearLayout>

            <LinearLayout style="@style/ReadColorRow">
                <io.legado.app.ui.widget.DetailSeekBar
                    android:id="@+id/dsb_text_letter_spacing"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:max="100"
                    app:title="@string/text_letter_spacing" />
            </LinearLayout>

            <LinearLayout style="@style/ReadColorRow">
                <io.legado.app.ui.widget.DetailSeekBar
                    android:id="@+id/dsb_line_size"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:max="20"
                    app:title="@string/line_size" />
            </LinearLayout>

            <LinearLayout style="@style/ReadColorRow">
                <io.legado.app.ui.widget.DetailSeekBar
                    android:id="@+id/dsb_paragraph_spacing"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:max="20"
                    app:title="@string/paragraph_size" />
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/panel_color_background"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_share_layout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/share_layout" />

                <io.legado.app.ui.widget.checkbox.SmoothCheckBox
                    android:id="@+id/cb_share_layout"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="4dp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/theme_mode_edit_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:minHeight="40dp"
                android:orientation="horizontal"
                android:paddingStart="8dp"
                android:paddingTop="5dp"
                android:paddingEnd="8dp"
                android:paddingBottom="5dp">

                <TextView
                    android:id="@+id/btn_theme_light"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:minHeight="34dp"
                    android:text="@string/theme_day"
                    android:textColor="@color/primaryText"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btn_theme_dark"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:minHeight="34dp"
                    android:text="@string/theme_night"
                    android:textColor="@color/primaryText"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btn_theme_eink"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:minHeight="34dp"
                    android:text="@string/manga_epaper"
                    android:textColor="@color/primaryText"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/row_text_color"
                style="@style/ReadColorRow">

                <TextView
                    android:id="@+id/tv_text_color"
                    style="@style/ReadColorRowTitle"
                    android:text="@string/text_color" />

                <View
                    android:id="@+id/vw_text_color_swatch"
                    style="@style/ReadColorRowSwatch" />

                <TextView
                    android:id="@+id/tv_text_color_value"
                    style="@style/ReadColorRowValue" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/row_bg_color"
                style="@style/ReadColorRow">

                <TextView
                    android:id="@+id/tv_bg_color"
                    style="@style/ReadColorRowTitle"
                    android:text="@string/bg_color" />

                <View
                    android:id="@+id/vw_bg_color_swatch"
                    style="@style/ReadColorRowSwatch" />

                <TextView
                    android:id="@+id/tv_bg_color_value"
                    style="@style/ReadColorRowValue" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/row_text_accent_color"
                style="@style/ReadColorRow">

                <TextView
                    android:id="@+id/tv_text_accent_color"
                    style="@style/ReadColorRowTitle"
                    android:text="@string/text_accent_color" />

                <View
                    android:id="@+id/vw_text_accent_color_swatch"
                    style="@style/ReadColorRowSwatch" />

                <TextView
                    android:id="@+id/tv_text_accent_color_value"
                    style="@style/ReadColorRowValue" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/row_menu_bg_color"
                style="@style/ReadColorRow">

                <TextView
                    android:id="@+id/tv_menu_bg_color"
                    style="@style/ReadColorRowTitle"
                    android:text="@string/read_menu_bg" />

                <View
                    android:id="@+id/vw_menu_bg_color_swatch"
                    style="@style/ReadColorRowSwatch" />

                <TextView
                    android:id="@+id/tv_menu_bg_color_value"
                    style="@style/ReadColorRowValue" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/row_read_menu_alpha"
                style="@style/ReadColorRow">

                <TextView
                    android:id="@+id/tv_read_menu_alpha"
                    style="@style/ReadColorRowTitle"
                    android:text="@string/read_menu_alpha" />

                <TextView
                    android:id="@+id/tv_read_menu_alpha_value"
                    style="@style/ReadColorRowValue" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/row_bg_image"
                style="@style/ReadColorRow">

                <TextView
                    android:id="@+id/tv_bg_image"
                    style="@style/ReadColorRowTitle"
                    android:text="@string/bg_image" />

                <ImageView
                    android:id="@+id/iv_bg_preview"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@color/background_menu"
                    android:contentDescription="@string/bg_image"
                    android:scaleType="centerCrop"
                    tool:src="@drawable/ic_image" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/row_bg_alpha"
                style="@style/ReadColorRow">

                <TextView
                    android:id="@+id/tv_bg_alpha"
                    style="@style/ReadColorRowTitle"
                    android:text="@string/bg_alpha" />

                <TextView
                    android:id="@+id/tv_bg_alpha_value"
                    style="@style/ReadColorRowValue" />
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/panel_page_anim"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/row_dark_status_icon"
                style="@style/ReadColorRow">

                <TextView
                    style="@style/ReadColorRowTitle"
                    android:text="@string/dark_status_icon" />

                <TextView
                    android:id="@+id/tv_dark_status_icon_value"
                    style="@style/ReadColorRowValue" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/row_scroll_follow_bg"
                style="@style/ReadColorRow">

                <TextView
                    style="@style/ReadColorRowTitle"
                    android:text="@string/read_scroll_follow_background" />

                <TextView
                    android:id="@+id/tv_scroll_follow_bg_value"
                    style="@style/ReadColorRowValue" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/row_padding"
                style="@style/ReadColorRow">

                <TextView
                    style="@style/ReadColorRowTitle"
                    android:text="@string/padding" />

                <TextView
                    android:id="@+id/tv_padding"
                    style="@style/ReadColorRowValue"
                    android:text="@string/setting" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/row_tip"
                style="@style/ReadColorRow">

                <TextView
                    style="@style/ReadColorRowTitle"
                    android:text="@string/information" />

                <TextView
                    android:id="@+id/tv_tip"
                    style="@style/ReadColorRowValue"
                    android:text="@string/setting" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/row_chinese_converter"
                style="@style/ReadColorRow">

                <TextView
                    style="@style/ReadColorRowTitle"
                    android:text="@string/chinese_converter" />

                <io.legado.app.ui.book.read.config.ChineseConverter
                    android:id="@+id/chinese_converter"
                    style="@style/ReadColorRowValue" />

            </LinearLayout>

            <TextView
                android:id="@+id/tv_page_anim"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/ReadColorRowTitle"
                android:layout_marginTop="8dp"
                android:text="@string/page_anim" />

            <GridLayout
                android:id="@+id/rg_page_anim"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:columnCount="3"
                android:rowCount="2">

                <io.legado.app.lib.theme.view.ThemeRadioNoButton
                    android:id="@+id/rb_anim0"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_marginTop="4dp"
                    android:layout_marginEnd="4dp"
                    android:layout_columnWeight="1"
                    android:button="@null"
                    android:gravity="center"
                    android:singleLine="true"
                    android:text="@string/page_anim_cover"
                    app:isBottomBackground="true" />

                <io.legado.app.lib.theme.view.ThemeRadioNoButton
                    android:id="@+id/rb_anim_linked_cover"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_marginTop="6dp"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:layout_columnWeight="1"
                    android:button="@null"
                    android:gravity="center"
                    android:singleLine="true"
                    android:text="@string/page_anim_linked_cover"
                    app:isBottomBackground="true" />

                <io.legado.app.lib.theme.view.ThemeRadioNoButton
                    android:id="@+id/rb_anim1"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_marginTop="6dp"
                    android:layout_marginStart="4dp"
                    android:layout_columnWeight="1"
                    android:button="@null"
                    android:gravity="center"
                    android:singleLine="true"
                    android:text="@string/page_anim_slide"
                    app:isBottomBackground="true" />

                <io.legado.app.lib.theme.view.ThemeRadioNoButton
                    android:id="@+id/rb_simulation_anim"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_marginTop="6dp"
                    android:layout_marginEnd="4dp"
                    android:layout_columnWeight="1"
                    android:button="@null"
                    android:gravity="center"
                    android:singleLine="true"
                    android:text="@string/page_anim_simulation"
                    app:isBottomBackground="true" />

                <io.legado.app.lib.theme.view.ThemeRadioNoButton
                    android:id="@+id/rb_scroll_anim"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_marginTop="6dp"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:layout_columnWeight="1"
                    android:button="@null"
                    android:gravity="center"
                    android:singleLine="true"
                    android:text="@string/page_anim_scroll"
                    app:isBottomBackground="true" />

                <io.legado.app.lib.theme.view.ThemeRadioNoButton
                    android:id="@+id/rb_no_anim"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_marginTop="6dp"
                    android:layout_marginStart="4dp"
                    android:layout_columnWeight="1"
                    android:button="@null"
                    android:gravity="center"
                    android:singleLine="true"
                    android:text="@string/page_anim_none"
                    app:isBottomBackground="true" />

            </GridLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
