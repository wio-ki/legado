<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/top_row"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="24dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tv_ai_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:includeFontPadding="false"
            android:text="@string/ai"
            android:textColor="@color/primaryText"
            android:textSize="24sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btn_ai_settings"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="@drawable/bg_discover_embedded_action"
            android:contentDescription="@string/ai_setting"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_settings"
            android:tint="@color/primaryText" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_ai_messages"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:paddingEnd="16dp"
        android:paddingBottom="96dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/top_row" />

    <LinearLayout
        android:id="@+id/thinking_panel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_ai_composer"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingTop="10dp"
        android:paddingEnd="14dp"
        android:paddingBottom="10dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/composer_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/tv_thinking_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:text="@string/ai_chat_thinking"
            android:textColor="@color/primaryText"
            android:textSize="13sp"
            android:textStyle="bold" />

        <androidx.core.widget.NestedScrollView
            android:id="@+id/thinking_scroll"
            android:layout_width="match_parent"
            android:layout_height="96dp"
            android:layout_marginTop="6dp"
            android:fadingEdgeLength="12dp"
            android:requiresFadingEdge="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_thinking_detail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/secondaryText"
                android:textSize="12sp" />

        </androidx.core.widget.NestedScrollView>

    </LinearLayout>

    <TextView
        android:id="@+id/tv_ai_empty"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:text="@string/ai_chat_empty"
        android:textColor="@color/secondaryText"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/top_row" />

    <LinearLayout
        android:id="@+id/composer_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="14dp"
        android:background="@drawable/bg_ai_surface_panel"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:minHeight="60dp"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:paddingEnd="12dp"
        android:paddingBottom="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <EditText
            android:id="@+id/et_ai_input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:gravity="center_vertical"
            android:hint="@string/ai_chat_hint"
            android:imeOptions="actionSend"
            android:inputType="textMultiLine|textCapSentences"
            android:maxLines="5"
            android:minHeight="44dp"
            android:paddingEnd="16dp"
            android:textColor="@color/primaryText"
            android:textColorHint="@color/secondaryText"
            android:textSize="15sp" />

        <io.legado.app.ui.widget.image.RatioIconButton
            android:id="@+id/btn_ai_send"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_ai_send_button"
            android:contentDescription="@string/ai_chat_send"
            android:scaleType="centerInside"
            android:src="@drawable/ic_arrow_right"
            android:tint="@color/white" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/nav_jump_container"
        android:layout_width="40dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="92dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btn_scroll_prev"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_ai_composer"
            android:elevation="6dp"
            android:padding="10dp"
            android:rotation="180"
            android:src="@drawable/ic_arrow_drop_down"
            android:tint="@color/primaryText" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btn_scroll_next"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_ai_composer"
            android:elevation="6dp"
            android:padding="10dp"
            android:src="@drawable/ic_arrow_drop_down"
            android:tint="@color/primaryText" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
