<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <io.legado.app.ui.book.read.page.ReadView
        android:id="@+id/read_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <View
        android:id="@+id/text_menu_position"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="invisible" />

    <ImageView
        android:id="@+id/cursor_left"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="@string/select_start"
        android:src="@drawable/ic_cursor_left"
        android:visibility="invisible" />

    <ImageView
        android:id="@+id/cursor_right"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="@string/select_end"
        android:src="@drawable/ic_cursor_right"
        android:visibility="invisible" />

    <io.legado.app.ui.book.read.ReadMenu
        android:id="@+id/read_menu"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <io.legado.app.ui.book.read.SearchMenu
        android:id="@+id/search_menu"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <io.legado.app.ui.book.read.ReadAiFloatingPanel
        android:id="@+id/read_ai_panel"
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/read_aloud_page_panel"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="28dp"
        android:background="@drawable/bg_read_aloud_page_panel"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/btn_read_aloud_original_progress"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:drawableStart="@drawable/ic_replay"
            android:drawablePadding="5dp"
            android:drawableTint="@android:color/white"
            android:gravity="center"
            android:minWidth="86dp"
            android:paddingStart="4dp"
            android:paddingEnd="8dp"
            android:text="@string/read_aloud_original_progress"
            android:textColor="@android:color/white"
            android:textSize="13sp" />

        <View
            android:layout_width="1dp"
            android:layout_height="18dp"
            android:background="#38FFFFFF" />

        <TextView
            android:id="@+id/btn_read_aloud_from_current_page"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:drawableStart="@drawable/ic_forward"
            android:drawablePadding="5dp"
            android:drawableTint="@android:color/white"
            android:gravity="center"
            android:minWidth="92dp"
            android:paddingStart="8dp"
            android:paddingEnd="4dp"
            android:text="@string/read_aloud_from_current_page"
            android:textColor="@android:color/white"
            android:textSize="13sp" />

    </LinearLayout>

    <View
        android:id="@+id/navigation_bar"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@color/background_menu"
        android:layout_gravity="bottom" />

</FrameLayout>
