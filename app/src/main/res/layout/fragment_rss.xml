<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <io.legado.app.ui.widget.TitleBar
        android:id="@+id/title_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:attachToActivity="false"
        app:contentLayout="@layout/view_search"
        app:layout_constraintTop_toTopOf="parent"
        app:title="@string/rss" />

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh_layout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/title_bar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="vertical"
            android:paddingStart="@dimen/bookshelf_tag_bar_margin_horizontal"
            android:paddingEnd="@dimen/bookshelf_tag_bar_margin_horizontal">

            <LinearLayout
                android:id="@+id/ll_rss_source_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="@dimen/bookshelf_title_row_margin_top"
                android:paddingBottom="0dp">

                <LinearLayout
                    android:id="@+id/ll_rss_source_select"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/bookshelf_title_select_height"
                    android:background="@drawable/bg_discover_embedded_action"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingEnd="0dp">

                    <TextView
                        android:id="@+id/tv_rss_source_select"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:textColor="@color/primaryText"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        tools:text="默认订阅源" />

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/iv_rss_source_arrow"
                        android:layout_width="@dimen/bookshelf_title_arrow_size"
                        android:layout_height="@dimen/bookshelf_title_arrow_size"
                        android:contentDescription="@string/rss"
                        android:src="@drawable/ic_arrow_drop_down"
                        app:tint="@color/primaryText" />

                </LinearLayout>

                <Space
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <androidx.appcompat.widget.AppCompatImageButton
                    android:id="@+id/btn_rss_source_search"
                    android:layout_width="@dimen/bookshelf_action_button_size"
                    android:layout_height="@dimen/bookshelf_action_button_size"
                    android:background="@drawable/bg_discover_embedded_action"
                    android:contentDescription="@string/search"
                    android:padding="@dimen/bookshelf_action_button_padding"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_search"
                    android:tint="@color/primaryText"
                    android:visibility="gone" />

                <Space
                    android:layout_width="10dp"
                    android:layout_height="1dp" />

                <androidx.appcompat.widget.AppCompatImageButton
                    android:id="@+id/btn_rss_more"
                    android:layout_width="@dimen/bookshelf_action_button_size"
                    android:layout_height="@dimen/bookshelf_action_button_size"
                    android:background="@drawable/bg_discover_embedded_action"
                    android:contentDescription="@string/menu"
                    android:padding="@dimen/bookshelf_action_button_padding"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_more_vert"
                    android:tint="@color/primaryText" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/ll_rss_tags_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/bookshelf_tag_bar_margin_top"
                android:orientation="vertical"
                android:visibility="gone" />

            <FrameLayout
                android:id="@+id/fl_rss_content"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="10dp"
                android:layout_weight="1"
                android:clipToPadding="false">

                <io.legado.app.ui.widget.recycler.RecyclerViewAtPager2
                    android:id="@+id/recycler_view"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone"
                    app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                    app:spanCount="1"
                    tools:listitem="@layout/item_rss" />

                <FrameLayout
                    android:id="@+id/rss_fragment_container"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone" />

                <FrameLayout
                    android:id="@+id/rss_web_container"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tv_empty_msg"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:padding="24dp"
                    android:text="@string/rss_source_empty"
                    android:textColor="@color/secondaryText"
                    android:textSize="14sp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/btn_open_rss"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_open_rss_button"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:minHeight="44dp"
                    android:paddingStart="20dp"
                    android:paddingTop="10dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="10dp"
                    android:textColor="@color/primaryText"
                    android:textSize="16sp"
                    android:visibility="gone"
                    tools:text="打开示例订阅" />

                <ProgressBar
                    android:id="@+id/pb_rss_loading"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:visibility="gone" />

            </FrameLayout>

        </LinearLayout>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
