<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <io.legado.app.ui.widget.TitleBar
        android:id="@+id/title_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:attachToActivity="false"
        app:contentLayout="@layout/view_search"
        app:layout_constraintTop_toTopOf="parent"
        app:title="@string/discovery" />

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh_layout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/title_bar">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:id="@+id/ll_modern_discovery"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:paddingStart="@dimen/bookshelf_tag_bar_margin_horizontal"
                android:paddingTop="0dp"
                android:paddingEnd="@dimen/bookshelf_tag_bar_margin_horizontal"
                android:paddingBottom="0dp"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/ll_discover_source_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingTop="@dimen/bookshelf_title_row_margin_top"
                    android:paddingBottom="0dp">

                    <LinearLayout
                        android:id="@+id/ll_discover_source_select"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/bookshelf_title_select_height"
                        android:background="@drawable/bg_discover_embedded_action"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="0dp"
                        android:paddingEnd="0dp">

                        <TextView
                            android:id="@+id/tv_discover_source_select"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:includeFontPadding="false"
                            android:maxLines="1"
                            android:textColor="@color/primaryText"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            tools:text="默认书源" />

                        <androidx.appcompat.widget.AppCompatImageView
                            android:id="@+id/iv_discover_source_arrow"
                            android:layout_width="@dimen/bookshelf_title_arrow_size"
                            android:layout_height="@dimen/bookshelf_title_arrow_size"
                            android:contentDescription="@string/discovery"
                            android:src="@drawable/ic_arrow_drop_down"
                            app:tint="@color/primaryText" />

                    </LinearLayout>

                    <Space
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <androidx.appcompat.widget.AppCompatImageButton
                        android:id="@+id/btn_discover_source_search"
                        android:layout_width="@dimen/bookshelf_action_button_size"
                        android:layout_height="@dimen/bookshelf_action_button_size"
                        android:background="@drawable/bg_discover_embedded_action"
                        android:contentDescription="@string/search"
                        android:padding="@dimen/bookshelf_action_button_padding"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_search"
                        android:tint="@color/primaryText"
                        android:visibility="gone" />

                    <Space
                        android:layout_width="10dp"
                        android:layout_height="1dp" />

                    <androidx.appcompat.widget.AppCompatImageButton
                        android:id="@+id/btn_discover_tag_filter"
                        android:layout_width="@dimen/bookshelf_action_button_size"
                        android:layout_height="@dimen/bookshelf_action_button_size"
                        android:background="@drawable/bg_discover_embedded_action"
                        android:contentDescription="@string/setting"
                        android:padding="@dimen/bookshelf_action_button_padding"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_settings"
                        android:tint="@color/primaryText" />

                    <Space
                        android:layout_width="10dp"
                        android:layout_height="1dp" />

                    <androidx.appcompat.widget.AppCompatImageButton
                        android:id="@+id/btn_discover_more"
                        android:layout_width="@dimen/bookshelf_action_button_size"
                        android:layout_height="@dimen/bookshelf_action_button_size"
                        android:background="@drawable/bg_discover_embedded_action"
                        android:contentDescription="@string/menu"
                        android:padding="@dimen/bookshelf_action_button_padding"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_more_vert"
                        android:tint="@color/primaryText" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ll_discover_selects_bar"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/bookshelf_tag_bar_height"
                    android:layout_marginTop="@dimen/bookshelf_tag_bar_margin_top"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:visibility="gone">

                    <io.legado.app.ui.widget.RoundedTagBarView
                        android:id="@+id/rv_discover_selects"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1" />

                    <androidx.appcompat.widget.AppCompatImageButton
                        android:id="@+id/btn_discover_selects_expand"
                        android:layout_width="@dimen/bookshelf_action_button_size"
                        android:layout_height="@dimen/bookshelf_action_button_size"
                        android:layout_marginStart="6dp"
                        android:background="@drawable/bg_discover_embedded_action"
                        android:contentDescription="@string/expand"
                        android:padding="@dimen/bookshelf_action_button_padding"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_arrow_drop_down"
                        android:tint="@color/primaryText" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ll_discover_tags_bar"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/bookshelf_tag_bar_height"
                    android:layout_marginTop="@dimen/bookshelf_tag_bar_margin_top"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <io.legado.app.ui.widget.RoundedTagBarView
                        android:id="@+id/rv_discover_tags"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1" />

                    <androidx.appcompat.widget.AppCompatImageButton
                        android:id="@+id/btn_discover_tags_expand"
                        android:layout_width="@dimen/bookshelf_action_button_size"
                        android:layout_height="@dimen/bookshelf_action_button_size"
                        android:layout_marginStart="6dp"
                        android:background="@drawable/bg_discover_embedded_action"
                        android:contentDescription="@string/expand"
                        android:padding="@dimen/bookshelf_action_button_padding"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_arrow_drop_down"
                        android:tint="@color/primaryText" />

                </LinearLayout>

                <FrameLayout
                    android:id="@+id/fl_discover_books"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="10dp"
                    android:layout_weight="1"
                    android:clipToPadding="false">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_discover_books"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:clipToPadding="false"
                        android:paddingBottom="14dp"
                        tools:listitem="@layout/item_search" />

                    <TextView
                        android:id="@+id/tv_discover_empty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:padding="24dp"
                        android:text="@string/explore_empty"
                        android:textColor="@color/secondaryText"
                        android:textSize="14sp"
                        android:visibility="gone" />

                    <LinearLayout
                        android:id="@+id/ll_discover_loading"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <ProgressBar
                            android:id="@+id/pb_discover_loading"
                            android:layout_width="28dp"
                            android:layout_height="28dp" />

                        <TextView
                            android:id="@+id/tv_discover_loading"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="@string/data_loading"
                            android:textColor="@color/secondaryText"
                            android:textSize="13sp" />

                    </LinearLayout>

                </FrameLayout>

            </LinearLayout>

            <io.legado.app.ui.widget.recycler.RecyclerViewAtPager2
                android:id="@+id/rv_find"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                tools:listitem="@layout/item_find_book" />

            <TextView
                android:id="@+id/tv_empty_msg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_margin="16dp"
                android:gravity="center"
                android:text="@string/explore_empty"
                android:visibility="gone"
                tools:text="TextView" />

        </FrameLayout>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
