<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <io.legado.app.ui.widget.TitleBar
        android:id="@+id/title_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <View
        android:id="@+id/collapsed_status_bar_spacer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@color/black"
        android:visibility="gone" />

    <io.legado.app.help.gsyVideo.VideoPlayer
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        tools:layout_height="300dp" />

    <FrameLayout
        android:id="@+id/bottom_panel_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:id="@+id/bottom_panel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginStart="12dp"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_book_info_intro_panel"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingTop="12dp"
            android:paddingEnd="14dp"
            android:paddingBottom="12dp"
            tools:visibility="gone">

            <LinearLayout
                android:id="@+id/detail_tabs"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:background="@android:color/transparent"
                android:gravity="center"
                android:orientation="horizontal"
                android:padding="3dp">

                <TextView
                    android:id="@+id/tab_intro"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_bookshelf_tag_item"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:text="@string/book_info_tab_intro"
                    android:textColor="@color/primaryText"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tab_toc"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_bookshelf_tag_item"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:text="@string/chapter_list"
                    android:textColor="@color/tv_text_summary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tab_info"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_bookshelf_tag_item"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:text="@string/book_info_tab_info"
                    android:textColor="@color/tv_text_summary"
                    android:textSize="14sp" />

                <ImageButton
                    android:id="@+id/btn_expand_bottom_panel_collapse"
                    android:layout_width="40dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/bg_bookshelf_tag_item"
                    android:contentDescription="@string/collapse"
                    android:padding="8dp"
                    android:src="@drawable/ic_arrow_drop_down"
                    app:tint="@color/tv_text_summary" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/panel_intro"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="10dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/data"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    tools:ignore="NestedWeights">

                    <TextView
                        android:id="@+id/tv_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:includeFontPadding="false"
                        android:singleLine="true"
                        android:text="@string/book_name"
                        android:textColor="@color/primaryText"
                        android:textSize="18sp" />

                    <TextView
                        android:id="@+id/tv_author"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:ellipsize="end"
                        android:includeFontPadding="false"
                        android:singleLine="true"
                        android:text="@string/author"
                        android:textColor="@color/tv_text_summary"
                        android:textSize="13sp" />

                    <androidx.core.widget.NestedScrollView
                        android:id="@+id/scroll_view_r"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_marginTop="8dp"
                        android:layout_weight="1">

                        <FrameLayout
                            android:id="@+id/tv_intro_container"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content" />
                    </androidx.core.widget.NestedScrollView>

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/chapters_container"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="12dp"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:visibility="gone">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/volumes"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:orientation="horizontal"
                    android:padding="0dp"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="vertical">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/chapters"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:padding="0dp"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/panel_info"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="12dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="0dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="17dp"
                        android:layout_height="17dp"
                        android:contentDescription="@string/change_origin"
                        android:src="@drawable/ic_exchange"
                        app:tint="@color/tv_text_summary" />

                    <TextView
                        android:id="@+id/tv_video_source"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:textColor="@color/tv_text_summary"
                        android:textSize="13.5sp"
                        tools:text="Source: example" />

                    <io.legado.app.ui.widget.text.AccentBgTextView
                        android:id="@+id/btn_change_source"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:paddingStart="10dp"
                        android:paddingTop="4dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="4dp"
                        android:text="@string/change_book_source_action"
                        android:textSize="12sp"
                        app:radius="5dp" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1px"
                    android:layout_marginTop="11dp"
                    android:layout_marginBottom="11dp"
                    android:background="@color/bg_divider_line" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="17dp"
                        android:layout_height="17dp"
                        android:contentDescription="@string/edit_source"
                        android:src="@drawable/ic_edit"
                        app:tint="@color/tv_text_summary" />

                    <TextView
                        android:id="@+id/tv_video_origin"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:textColor="@color/tv_text_summary"
                        android:textSize="13.5sp"
                        tools:text="Origin: example" />

                    <io.legado.app.ui.widget.text.AccentBgTextView
                        android:id="@+id/btn_edit_source"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:paddingStart="10dp"
                        android:paddingTop="4dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="4dp"
                        android:text="@string/edit_source"
                        android:textSize="12sp"
                        app:radius="5dp" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1px"
                    android:layout_marginTop="11dp"
                    android:layout_marginBottom="11dp"
                    android:background="@color/bg_divider_line" />

                <LinearLayout
                    android:id="@+id/ll_login_source"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="17dp"
                        android:layout_height="17dp"
                        android:contentDescription="@string/login"
                        android:src="@drawable/ic_web_outline"
                        app:tint="@color/tv_text_summary" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:text="@string/login"
                        android:textColor="@color/tv_text_summary"
                        android:textSize="13.5sp" />

                    <io.legado.app.ui.widget.text.AccentBgTextView
                        android:id="@+id/btn_login_source"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:paddingStart="10dp"
                        android:paddingTop="4dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="4dp"
                        android:text="@string/login"
                        android:textSize="12sp"
                        app:radius="5dp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/bottom_panel_collapsed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="7dp"
            android:layout_marginBottom="7dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone"
            tools:visibility="visible">

            <LinearLayout
                android:id="@+id/bottom_panel_collapsed_bar"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_book_info_intro_panel"
                android:clickable="true"
                android:contentDescription="@string/expand"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="12dp">

                <TextView
                    android:id="@+id/tv_collapsed_episode"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:textColor="@color/primaryText"
                    android:textSize="15sp"
                    tools:text="1/12" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="@string/expand"
                    android:src="@drawable/ic_arrow_drop_up"
                    app:tint="@color/tv_text_summary" />

            </LinearLayout>

            <ImageButton
                android:id="@+id/btn_collapsed_float_window"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:background="@color/transparent"
                android:contentDescription="@string/float_window"
                android:padding="0dp"
                android:src="@drawable/ic_float_window"
                app:tint="@color/primaryText" />


            <TextView
                android:id="@+id/btn_collapsed_playback_speed"
                android:layout_width="42dp"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:background="@color/transparent"
                android:contentDescription="@string/playback_speed"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="@string/playback_speed"
                android:textColor="@color/primaryText"
                android:textSize="13sp" />

        </LinearLayout>

    </FrameLayout>

</LinearLayout>
