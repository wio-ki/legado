<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/bg_book"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@string/bg_image"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/vw_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:clipToPadding="false">

        <io.legado.app.ui.widget.TitleBar
            android:id="@+id/title_bar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:title="@string/book_info"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/refresh_layout"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintBottom_toTopOf="@id/fl_action"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/title_bar">

            <io.legado.app.ui.widget.NoChildScrollNestedScrollView
                android:id="@+id/scroll_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:fitsSystemWindows="false"
                android:focusable="true"
                android:scrollbarStyle="outsideOverlay"
                android:scrollbars="vertical">

                <LinearLayout
                    android:id="@+id/ll_info"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/transparent"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingTop="16dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="12dp">

                    <LinearLayout
                        android:id="@+id/ll_detail_panel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_book_info_intro_panel"
                        android:gravity="top"
                        android:orientation="horizontal"
                        android:paddingStart="14dp"
                        android:paddingTop="14dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="14dp">

                        <androidx.cardview.widget.CardView
                            android:id="@+id/iv_cover_c"
                            android:layout_width="108dp"
                            android:layout_height="144dp"
                            android:layout_marginEnd="16dp"
                            app:cardCornerRadius="@dimen/ui_panel_radius"
                            app:cardElevation="4dp">

                            <io.legado.app.ui.widget.image.CoverImageView
                                android:id="@+id/iv_cover"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:contentDescription="@string/img_cover"
                                android:scaleType="centerCrop"
                                android:src="@drawable/image_cover_default" />

                        </androidx.cardview.widget.CardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:minHeight="144dp"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tv_name"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:ellipsize="end"
                                android:includeFontPadding="false"
                                android:maxLines="2"
                                android:text="@string/book_name"
                                android:textColor="@color/primaryText"
                                android:textSize="21sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_author"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:ellipsize="end"
                                android:includeFontPadding="false"
                                android:maxLines="1"
                                android:text="@string/author"
                                android:textColor="@color/tv_text_summary"
                                android:textSize="14sp" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <ImageView
                                    android:id="@+id/ic_book_last"
                                    android:layout_width="15dp"
                                    android:layout_height="15dp"
                                    android:contentDescription="@string/read_dur_progress"
                                    android:src="@drawable/ic_book_last"
                                    app:tint="@color/tv_text_summary" />

                                <TextView
                                    android:id="@+id/tv_lasted"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="7dp"
                                    android:layout_weight="1"
                                    android:ellipsize="end"
                                    android:includeFontPadding="false"
                                    android:maxLines="1"
                                    android:textColor="@color/tv_text_summary"
                                    android:textSize="12.5sp"
                                    tools:text="@string/read_dur_progress" />

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <ImageView
                                    android:layout_width="15dp"
                                    android:layout_height="15dp"
                                    android:contentDescription="@string/reading_time_tag"
                                    android:src="@drawable/ic_timer_black_24dp"
                                    app:tint="@color/tv_text_summary" />

                                <TextView
                                    android:id="@+id/tv_read_time"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="7dp"
                                    android:layout_weight="1"
                                    android:ellipsize="end"
                                    android:includeFontPadding="false"
                                    android:maxLines="1"
                                    android:textColor="@color/tv_text_summary"
                                    android:textSize="12.5sp"
                                    tools:text="@string/reading_time_tag" />

                            </LinearLayout>

                            <HorizontalScrollView
                                android:layout_width="match_parent"
                                android:layout_height="34dp"
                                android:layout_marginTop="10dp"
                                android:scrollbars="none">

                                <io.legado.app.ui.widget.LabelsBar
                                    android:id="@+id/lb_kind"
                                    android:layout_width="wrap_content"
                                    android:layout_height="28dp"
                                    android:visibility="gone" />
                            </HorizontalScrollView>

                        </LinearLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/ll_info_page"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_book_info_intro_panel"
                        android:orientation="vertical"
                        android:paddingStart="14dp"
                        android:paddingTop="12dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="12dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="17dp"
                                android:layout_height="17dp"
                                android:contentDescription="@string/read_dur_progress"
                                android:src="@drawable/ic_groups"
                                app:tint="@color/tv_text_summary" />

                            <TextView
                                android:id="@+id/tv_group"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:layout_weight="1"
                                android:ellipsize="end"
                                android:includeFontPadding="false"
                                android:maxLines="1"
                                android:textColor="@color/tv_text_summary"
                                android:textSize="13.5sp"
                                tools:text="@string/group_s" />

                            <io.legado.app.ui.widget.text.AccentBgTextView
                                android:id="@+id/tv_change_group"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:paddingStart="10dp"
                                android:paddingTop="4dp"
                                android:paddingEnd="10dp"
                                android:paddingBottom="4dp"
                                android:text="@string/change_group"
                                android:textSize="12sp"
                                app:radius="5dp" />

                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1px"
                            android:layout_marginTop="11dp"
                            android:layout_marginBottom="11dp"
                            android:background="@color/bg_divider_line" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="17dp"
                                android:layout_height="17dp"
                                android:contentDescription="@string/change_origin"
                                android:src="@drawable/ic_exchange"
                                app:tint="@color/tv_text_summary" />

                            <TextView
                                android:id="@+id/tv_origin"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:layout_weight="1"
                                android:ellipsize="end"
                                android:includeFontPadding="false"
                                android:maxLines="1"
                                android:textColor="@color/tv_text_summary"
                                android:textSize="13.5sp"
                                tools:text="@string/origin_format" />

                            <io.legado.app.ui.widget.text.AccentBgTextView
                                android:id="@+id/tv_change_source"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:paddingStart="10dp"
                                android:paddingTop="4dp"
                                android:paddingEnd="10dp"
                                android:paddingBottom="4dp"
                                android:text="@string/change_book_source_action"
                                android:textSize="12sp"
                                app:radius="5dp" />

                        </LinearLayout>

                        <View
                            android:id="@+id/divider_toc"
                            android:layout_width="match_parent"
                            android:layout_height="1px"
                            android:layout_marginTop="11dp"
                            android:layout_marginBottom="11dp"
                            android:background="@color/bg_divider_line"
                            android:visibility="gone" />

                        <LinearLayout
                            android:id="@+id/ll_toc"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:visibility="gone">

                            <ImageView
                                android:layout_width="17dp"
                                android:layout_height="17dp"
                                android:contentDescription="@string/read_dur_progress"
                                android:src="@drawable/ic_folder_open"
                                app:tint="@color/tv_text_summary" />

                            <TextView
                                android:id="@+id/tv_toc"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:layout_weight="1"
                                android:ellipsize="end"
                                android:includeFontPadding="false"
                                android:maxLines="1"
                                android:textColor="@color/tv_text_summary"
                                android:textSize="13.5sp"
                                tools:text="@string/toc_s" />

                            <io.legado.app.ui.widget.text.AccentBgTextView
                                android:id="@+id/tv_toc_view"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:paddingStart="10dp"
                                android:paddingTop="4dp"
                                android:paddingEnd="10dp"
                                android:paddingBottom="4dp"
                                android:text="@string/view_toc"
                                android:textSize="12sp"
                                app:radius="5dp" />

                        </LinearLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/ll_detail_content_panel"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_marginTop="14dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_book_info_intro_panel"
                        android:minHeight="260dp"
                        android:orientation="vertical"
                        android:paddingStart="14dp"
                        android:paddingTop="12dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="12dp">

                    <LinearLayout
                        android:id="@+id/ll_detail_tabs"
                        android:layout_width="match_parent"
                        android:layout_height="38dp"
                        android:background="@android:color/transparent"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:padding="3dp">

                        <TextView
                            android:id="@+id/tv_tab_intro"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@drawable/bg_bookshelf_tag_item"
                            android:gravity="center"
                            android:includeFontPadding="false"
                            android:text="@string/book_info_tab_intro"
                            android:textColor="@color/primaryText"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tv_tab_toc"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@drawable/bg_bookshelf_tag_item"
                            android:gravity="center"
                            android:includeFontPadding="false"
                            android:text="@string/book_info_tab_toc"
                            android:textColor="@color/tv_text_summary"
                            android:textSize="14sp" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/ll_toc_page"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_marginTop="12dp"
                        android:layout_weight="1"
                        android:background="@color/transparent"
                        android:orientation="vertical"
                        android:padding="0dp"
                        android:visibility="gone">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <io.legado.app.ui.widget.NoParentInterceptNestedScrollView
                                android:id="@+id/toc_scroll_view"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:fillViewport="false"
                                android:scrollbarStyle="outsideOverlay"
                                android:scrollbars="vertical">

                                <LinearLayout
                                    android:id="@+id/ll_toc_preview"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical" />

                            </io.legado.app.ui.widget.NoParentInterceptNestedScrollView>

                            <ImageView
                                android:id="@+id/iv_toc_fullscreen"
                                android:layout_width="42dp"
                                android:layout_height="42dp"
                                android:layout_gravity="end|bottom"
                                android:background="@drawable/bg_book_info_subtle_button"
                                android:clickable="true"
                                android:contentDescription="@string/view_toc"
                                android:focusable="true"
                                android:padding="9dp"
                                android:src="@drawable/ic_fullscreen"
                                android:visibility="gone"
                                app:tint="@color/accent" />

                        </FrameLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/ll_intro_page"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_marginTop="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <FrameLayout
                            android:id="@+id/tv_intro_container"
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1" />

                        <TextView
                            android:id="@+id/tv_intro_toggle"
                            android:layout_width="wrap_content"
                            android:layout_height="34dp"
                            android:layout_gravity="end"
                            android:layout_marginTop="6dp"
                            android:background="@drawable/bg_book_info_subtle_button"
                            android:gravity="center"
                            android:includeFontPadding="false"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:text="@string/expand"
                            android:textColor="@color/accent"
                            android:textSize="13sp"
                            android:visibility="gone" />

                    </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </io.legado.app.ui.widget.NoChildScrollNestedScrollView>

        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

        <LinearLayout
            android:id="@+id/fl_action"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingTop="10dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <TextView
                android:id="@+id/tv_shelf"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_book_info_action_secondary"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="@string/remove_from_bookshelf"
                android:textColor="@color/primaryText"
                android:textSize="15sp" />

            <io.legado.app.ui.widget.text.AccentBgTextView
                android:id="@+id/tv_read"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="@string/reading"
                android:textSize="15sp"
                app:radius="14dp" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
