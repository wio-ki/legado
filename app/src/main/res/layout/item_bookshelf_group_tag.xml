    android:minWidth="@dimen/bookshelf_tag_item_min_width"
    android:paddingStart="@dimen/bookshelf_tag_item_padding_horizontal"
    android:paddingEnd="@dimen/bookshelf_tag_item_padding_horizontal"
    android:singleLine="true"
    android:textColor="@color/selector_bookshelf_tag_text"
    android:textSize="13sp"
    android:textStyle="normal" />
